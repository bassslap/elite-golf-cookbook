<%
  # Simple server-side time endpoint
  # This will be processed by the web server to return current server time
  require 'json'
  require 'time'

  time_data = {
    'timestamp' => Time.now.to_i,
    'datetime' => Time.now.strftime('%m/%d/%Y, %I:%M:%S %p'),
    'timezone' => '<%= node["time"]["timezone"] rescue "Unknown" %>',
    'server' => '<%= node["hostname"] %>',
    'platform' => '<%= node["platform"].capitalize %> <%= node["platform_version"] %>'
  }
%><%= time_data.to_json %>
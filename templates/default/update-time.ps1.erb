# PowerShell script to update server time JSON file
$webRoot = "<%= @web_root %>"
$timeFile = Join-Path $webRoot "server-time.json"

# Get current time information
$now = Get-Date
$timestamp = [Math]::Floor($now.ToUniversalTime().Subtract((Get-Date "1/1/1970")).TotalSeconds)
$displayTime = $now.ToString("MM/dd/yyyy, hh:mm:ss tt")

# Create JSON object
$timeData = @{
    timestamp = $timestamp
    datetime = $displayTime
    timezone = "<%= @timezone rescue 'Unknown' %>"
    server = "<%= @hostname %>"
    platform = "<%= @platform.capitalize %> <%= @platform_version %>"
    updated = $now.ToString("yyyy-MM-dd HH:mm:ss")
} | ConvertTo-Json -Compress

# Write to file atomically
$tempFile = "$timeFile.tmp"
$timeData | Out-File -FilePath $tempFile -Encoding UTF8 -NoNewline
Move-Item $tempFile $timeFile -Force
#!/bin/bash
# Shell script to update server time JSON file

WEB_ROOT="/var/www/html/golf"
TIME_FILE="$WEB_ROOT/server-time.json"

# Current time
timestamp=$(date +%s)
datetime=$(date '+%m/%d/%Y, %I:%M:%S %p')
updated=$(date '+%Y-%m-%d %H:%M:%S')

# Read actual operating system timezone
timezone=$(timedatectl show --property=Timezone --value 2>/dev/null)

# Fallback if timedatectl is unavailable
if [ -z "$timezone" ]; then
    timezone=$(date +%Z)
fi

cat > "${TIME_FILE}.tmp" << EOF
{
    "timestamp": $timestamp,
    "datetime": "$datetime",
    "timezone": "$timezone",
    "server": "<%= node['hostname'] %>",
    "platform": "<%= node['platform'].capitalize %> <%= node['platform_version'] %>",
    "architecture": "<%= node['kernel']['machine'] %>",
    "chef_version": "<%= node['chef_packages']['chef']['version'] %>",
    "updated": "$updated"
}
EOF

# Move the file to web frontend
mv "${TIME_FILE}.tmp" "$TIME_FILE"

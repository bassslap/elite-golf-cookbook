<%# PowerShell script to return current server time as JSON %>
# Get current time
$now = Get-Date

# Format for display  
$displayTime = $now.ToString("MM/dd/yyyy, hh:mm:ss tt")

# Create JSON response
$response = @{
    timestamp = [Math]::Floor((Get-Date).ToUniversalTime().Subtract((Get-Date "1/1/1970")).TotalSeconds)
    datetime = $displayTime
    timezone = "<%= node['time']['timezone'] rescue 'Unknown' %>"
    server = "<%= node['hostname'] %>"
    platform = "<%= node['platform'].capitalize %> <%= node['platform_version'] %>"
} | ConvertTo-Json

# Set content type and output
Write-Output "Content-Type: application/json"
Write-Output ""
Write-Output $response
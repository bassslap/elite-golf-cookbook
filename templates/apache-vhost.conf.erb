<VirtualHost *:<%= node['golf_app']['port'] %>>
    ServerName <%= node['fqdn'] || 'localhost' %>
    DocumentRoot <%= node['golf_app']['web_root'] %>
    
    <Directory <%= node['golf_app']['web_root'] %>>
        Options Indexes FollowSymLinks
        AllowOverride None
        Require all granted
        DirectoryIndex index.html
    </Directory>
    
    # Enable compression
    <IfModule mod_deflate.c>
        AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript
    </IfModule>
    
    # Set proper MIME types
    <IfModule mod_mime.c>
        AddType text/html .html
        AddType text/css .css
        AddType application/javascript .js
        AddType image/svg+xml .svg
    </IfModule>
    
    # Security headers
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    
    # Custom error pages
    ErrorDocument 404 /index.html
    
    # Logging
    ErrorLog ${APACHE_LOG_DIR}/golf_error.log
    CustomLog ${APACHE_LOG_DIR}/golf_access.log combined
</VirtualHost>

<% if node['golf_app']['enable_ssl'] %>
<VirtualHost *:<%= node['golf_app']['ssl_port'] %>>
    ServerName <%= node['fqdn'] || 'localhost' %>
    DocumentRoot <%= node['golf_app']['web_root'] %>
    
    SSLEngine on
    SSLCertificateFile /etc/ssl/certs/golf-cert.pem
    SSLCertificateKeyFile /etc/ssl/private/golf-key.pem
    
    <Directory <%= node['golf_app']['web_root'] %>>
        Options Indexes FollowSymLinks
        AllowOverride None
        Require all granted
        DirectoryIndex index.html
    </Directory>
    
    # Enable compression
    <IfModule mod_deflate.c>
        AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript
    </IfModule>
    
    # Security headers
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    
    ErrorLog ${APACHE_LOG_DIR}/golf_ssl_error.log
    CustomLog ${APACHE_LOG_DIR}/golf_ssl_access.log combined
</VirtualHost>
<% end %>